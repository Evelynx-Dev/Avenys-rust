load kioto

pub fn main: () {
    set outer = 0 :i64 mut
    set inner = 0 :i64 mut
    set total = 0 :i64 mut
    
    while outer < 3 {
        set inner = 0 :i64 mut
        while inner < 3 {
            set total = total + 1
            set inner = inner + 1
        }
        set outer = outer + 1
    }
    
    use dasu(total)
}