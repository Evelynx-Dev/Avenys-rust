load kioto

pub skill Show {
    fn show: (self) :str
}

pub skill Size {
    fn size: (self) :i64
}

struct Box {
    items :i64
}

impl Show for Box {
    fn show: (self) :str {
        return "box"
    }
}

impl Size for Box {
    fn size: (self) :i64 {
        return self.items
    }
}

pub fn main: () {
    set b = (Box items: 5)
    set s = b.show()
    set n = b.size()
    use dasu(s)
    use dasu(n)
}