load kioto

enum Status {
    Ok
    Error
}

pub fn main: () {
    set r = Status.Ok
    set m1 = match r {
        Status.Ok { "success" }
        Status.Error { "failed" }
    } :str
    use dasu(m1)

    set r2 = Status.Error
    set m2 = match r2 {
        Status.Ok { "success" }
        Status.Error { "failed" }
    } :str
    use dasu(m2)
}