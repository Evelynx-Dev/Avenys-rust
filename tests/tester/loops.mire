import std

pub fn main: () {
    set i = 0 :i64 mut
    set sum = 0 :i64 mut
    while i < 5 {
        set sum = sum + i
        set i = i + 1
    }
    use dasu(sum)
    
    set j = 0 :i64 mut
    set total = 0 :i64 mut
    while j < 10 {
        set total = total + j
        set j = j + 1
    }
    use dasu(total)
    
    set done = true :bool
    if done {
        use dasu(done)
    }
}