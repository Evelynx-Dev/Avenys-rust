import std

fn add: (a :i64, b :i64) :i64 {
    return a + b
}

fn greet: (name :str) :str {
    return "hello " + name
}

pub fn main: () {
    set sum = add(5, 3)
    use dasu(sum)
    
    set message = greet("world")
    use dasu(message)
    
    set nested = add(add(1, 2), add(3, 4))
    use dasu(nested)
}