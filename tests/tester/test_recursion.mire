load kioto

fn factorial: (n :i64) :i64 {
    if n <= 1 {
        return 1
    } else {
        return n * factorial(n - 1)
    }
}

fn fibonacci: (n :i64) :i64 {
    if n <= 1 {
        return n
    } else {
        return fibonacci(n - 1) + fibonacci(n - 2)
    }
}

pub fn main: () {
    set f5 = factorial(5)
    use dasu(f5)
    
    set fib6 = fibonacci(6)
    use dasu(fib6)
}