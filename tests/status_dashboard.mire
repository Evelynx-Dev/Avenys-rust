load kioto::lists as lists
load kioto::time as time

pub fn main: () {
set started = time.mark() :i64 mut

set queue = [] :vec[i64] mut
set queue = lists.push(queue 10)
set queue = lists.push(queue 12)
set queue = lists.push(queue 3)

use dasu("queue size {len(queue)}")
use dasu("first ticket {lists.get(queue 0)}")
use dasu("elapsed {time.elapsed_ms(started)}")
}
