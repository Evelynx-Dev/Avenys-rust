// Test: multiple module imports compose
import std
import math
import lists
import strings

pub fn main: () {
    // Build a list of squares
    set xs = [] :vec[i64] mut
    set xs = lists.push(xs, 1)
    set xs = lists.push(xs, 2)
    set xs = lists.push(xs, 3)
    set xs = lists.push(xs, 4)
    set xs = lists.push(xs, 5)

    set total = math.sum(xs)
    set avg = total / lists.len(xs)

    use dasu("sum={total} avg={avg} len={lists.len(xs)}")
}
