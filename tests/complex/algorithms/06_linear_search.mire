load kioto

struct SearchResult {
    found :bool
    index :i64
}

fn linear_search: (arr :arr[i64 5], target :i64) :SearchResult {
    set i = 0 :i64 mut
    while i < 5 {
        set val = arr at i
        if val == target {
            return (SearchResult found: true, index: i)
        }
        set i = i + 1
    }
    return (SearchResult found: false, index: -1)
}

pub fn main: () {
    set arr = [10 20 30 40 50] :arr[i64 5]

    set arr_copy = arr
    set r1 = linear_search(arr_copy 30)

    set arr_copy2 = arr
    set r2 = linear_search(arr_copy2 25)

    use dasu("found 30: {r1.found}, index: {r1.index}")
    use dasu("found 25: {r2.found}, index: {r2.index}")
}