import std

pub fn main: () {
    set v1 = [] :vec[i64] mut
    set v1 = lists.push(v1 10)
    set v1 = lists.push(v1 20)
    set v1 = lists.push(v1 30)
    set v1 = lists.push(v1 40)
    set v1 = lists.push(v1 50)

    set v2 = [] :vec[i64] mut
    set v2 = lists.push(v2 5)
    set v2 = lists.push(v2 15)
    set v2 = lists.push(v2 25)

    set combined = [] :vec[i64] mut
    set i = 0 :i64 mut
    while i < 5 {
        set combined = lists.push(combined lists.get(v1 i))
        set i = i + 1
    }
    set i = 0 :i64 mut
    while i < 3 {
        set combined = lists.push(combined lists.get(v2 i))
        set i = i + 1
    }

    set total_len = len(combined)
    set first = lists.get(combined 0)
    set last = lists.get(combined 7)

    use dasu("Combined length: {total_len}")
    use dasu("First: {first}, Last: {last}")
}