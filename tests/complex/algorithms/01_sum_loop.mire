import std

pub fn main: () {
    set nums = [] :vec[i64] mut
    set nums = lists.push(nums 1)
    set nums = lists.push(nums 2)
    set nums = lists.push(nums 3)
    set nums = lists.push(nums 4)
    set nums = lists.push(nums 5)

    set total = 0 :i64 mut
    set i = 0 :i64 mut

    while i < 5 {
        set val = lists.get(nums i)
        set total = total + val
        set i = i + 1
    }

    use dasu("Sum of 1..5: {total}")
}
