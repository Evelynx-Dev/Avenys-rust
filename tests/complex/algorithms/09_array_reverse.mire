import std

fn reverse_array: (arr :arr[i64 5]) :vec[i64] {
    set a0 = arr at 0
    set a1 = arr at 1
    set a2 = arr at 2
    set a3 = arr at 3
    set a4 = arr at 4

    set result = [a4 a3 a2 a1 a0] :vec[i64] mut
    return result
}

pub fn main: () {
    set arr = [1 2 3 4 5] :arr[i64 5]

    set rev = reverse_array(arr)

    set r0 = rev at 0
    set r1 = rev at 1
    set r2 = rev at 2
    set r3 = rev at 3
    set r4 = rev at 4

    use dasu("Original: 1 2 3 4 5")
    use dasu("Reversed: {r0} {r1} {r2} {r3} {r4}")
}