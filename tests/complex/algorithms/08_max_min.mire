import std

pub fn main: () {
    set nums = [34 78 12 56 90] :arr[i64 5]

    set max = nums at 0 :i64 mut
    set min = nums at 0 :i64 mut
    set i = 1 :i64 mut

    while i < 5 {
        set current = nums at i
        if current > max {
            set max = current
        }
        if current < min {
            set min = current
        }
        set i = i + 1
    }

    use dasu("max={max} min={min}")
}