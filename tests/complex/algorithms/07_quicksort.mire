import std

fn quicksort_inner: (arr :arr[i64 8], left :i64, right :i64) {
    if left >= right {
        return
    }

    set pivot = arr at right
    set i = left :i64 mut
    set j = left :i64 mut

    while j < right {
        if arr at j < pivot {
            set temp_i = arr at i
            set temp_j = arr at j
            set arr at i = temp_j
            set arr at j = temp_i
            set i = i + 1
        }
        set j = j + 1
    }

    set temp_i = arr at i
    set temp_pivot = arr at right
    set arr at i = temp_pivot
    set arr at right = temp_i

    quicksort_inner(arr left i - 1)
    quicksort_inner(arr i + 1 right)
}

fn quicksort: (arr :arr[i64 8]) {
    quicksort_inner(arr 0 7)
}

pub fn main: () {
    set arr = [64 34 25 12 22 11 90 5] :arr[i64 8]

    quicksort(arr)

    set v0 = arr at 0
    set v3 = arr at 3
    set v7 = arr at 7

    use dasu("sorted[0]={v0} sorted[3]={v3} sorted[7]={v7}")
}