import std

struct SearchResult {
    found :bool
    index :i64
}

fn binary_search: (arr :arr[i64 8], target :i64) :SearchResult {
    set left = 0 :i64 mut
    set right = 7 :i64 mut

    while left <= right {
        set mid = (left + right) / 2
        set val = arr at mid

        if val == target {
            return (SearchResult found: true, index: mid)
        }
        if val < target {
            set left = mid + 1
        } else {
            set right = mid - 1
        }
    }

    return (SearchResult found: false, index: -1)
}

pub fn main: () {
    set arr = [1 3 5 7 9 11 13 15] :arr[i64 8]

    set arr1 = arr
    set r1 = binary_search(arr1 7)

    set arr2 = arr
    set r2 = binary_search(arr2 10)

    set arr3 = arr
    set r3 = binary_search(arr3 9)

    set arr4 = arr
    set r4 = binary_search(arr4 15)

    use dasu("found 7: {r1.found}, index: {r1.index}")
    use dasu("found 10: {r2.found}, index: {r2.index}")
    use dasu("found 9: {r3.found}, index: {r3.index}")
    use dasu("found 15: {r4.found}, index: {r4.index}")
}