import std

pub fn main: () {
    set result = lists.fold(0, (a b) => a + b, [1 2 3 4 5])
    use dasu("Sum with fold: {result}")

    set product = lists.fold(1, (a b) => a * b, [1 2 3 4 5])
    use dasu("Product with fold: {product}")

    set doubled = lists.map((x) => x * 2, [1 2 3 4 5])
    set d0 = lists.get(doubled 0)
    set d4 = lists.get(doubled 4)
    use dasu("Doubled: {d0} ... {d4}")

    set filtered = lists.filter((x) => x > 2, [1 2 3 4 5])
    set f0 = lists.get(filtered 0)
    set f2 = lists.get(filtered 2)
    use dasu("Filtered > 2: {f0} ... {f2}")
}
