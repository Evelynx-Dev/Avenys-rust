import std

fn fibonacci: (n :i64) :i64 {
    if n <= 1 {
        return n
    }
    return fibonacci(n - 1) + fibonacci(n - 2)
}

pub fn main: () {
    set f0 = fibonacci(0)
    set f1 = fibonacci(1)
    set f5 = fibonacci(5)
    set f10 = fibonacci(10)

    use dasu("fib(0) = {f0}")
    use dasu("fib(1) = {f1}")
    use dasu("fib(5) = {f5}")
    use dasu("fib(10) = {f10}")
}
