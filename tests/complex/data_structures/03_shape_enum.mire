import std

enum Shape {
    Circle(radius :i64)
    Rectangle(width :i64, height :i64)
    Triangle(base :i64, height :i64)
}

fn area: (s :Shape) :i64 {
    match s {
        Shape.Circle(r) {
            return r * r * 3
        }
        Shape.Rectangle(w h) {
            return w * h
        }
        Shape.Triangle(b h) {
            return (b * h) / 2
        }
    }
}

pub fn main: () {
    set c = Shape.Circle(radius: 5)
    set r = Shape.Rectangle(width: 4, height: 6)
    set t = Shape.Triangle(base: 3, height: 4)

    set ca = area(c)
    set ra = area(r)
    set ta = area(t)

    use dasu("Circle area: {ca}")
    use dasu("Rectangle area: {ra}")
    use dasu("Triangle area: {ta}")
}
