import std

struct Counter {
    value :i64 mut
    step :i64
}

impl Counter {
    fn new: (step :i64) :Counter {
        return (Counter value: 0, step: step)
    }

    fn increment: (self) {
        set self.value = self.value + self.step
    }

    fn get: (self) :i64 {
        return self.value
    }

    fn reset: (self) {
        set self.value = 0
    }
}

pub fn main: () {
    set c = Counter::new(5)

    c.increment()
    set v1 = c.get()
    c.increment()
    set v2 = c.get()
    c.increment()
    set v3 = c.get()

    use dasu("After 1 increment: {v1}")
    use dasu("After 2 increments: {v2}")
    use dasu("After 3 increments: {v3}")

    c.reset()
    set v4 = c.get()
    use dasu("After reset: {v4}")
}