import std

struct Math {
    base :i64
}

impl Math {
    fn new: (base :i64) :Math {
        return (Math base: base)
    }

    fn add: (self, val :i64) :i64 {
        return self.base + val
    }

    fn multiply: (self, val :i64) :i64 {
        return self.base * val
    }

    fn power: (self, exp :i64) :i64 {
        set result = 1 :i64 mut
        set i = 0 :i64 mut
        while i < exp {
            set result = result * self.base
            set i = i + 1
        }
        return result
    }
}

pub fn main: () {
    set m = Math::new(2)

    set a = m.add(5)
    set b = m.multiply(3)
    set c = m.power(4)

    use dasu("2 + 5 = {a}")
    use dasu("2 * 3 = {b}")
    use dasu("2^4 = {c}")
}