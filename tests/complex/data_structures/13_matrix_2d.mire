load kioto

pub fn main: () {
    set matrix = [[1 2 3] [4 5 6] [7 8 9]] :arr[arr[i64 3] 3]

    set row0 = matrix at 0
    set row1 = matrix at 1
    set row2 = matrix at 2

    set v00 = row0 at 0
    set v11 = row1 at 1
    set v22 = row2 at 2

    use dasu("matrix[0][0]={v00} matrix[1][1]={v11} matrix[2][2]={v22}")
}