load kioto

enum Result {
    Ok(value :i64)
    Err(msg :str)
}

fn handle: (r :Result) {
    match r {
        Result.Ok(v) {
            use dasu("ok: {v}")
        }
        Result.Err(m) {
            use dasu("err: {m}")
        }
    }
}

pub fn main: () {
    set r1 = Result.Ok(42)
    set r2 = Result.Err("error" :str)

    handle(r1)
    handle(r2)
}