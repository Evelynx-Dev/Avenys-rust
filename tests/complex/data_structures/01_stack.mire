import std

struct Stack {
    items :vec[i64] mut
    top :i64
}

impl Stack {
    fn new: () :Stack {
        return (Stack items: [] :vec[i64], top: -1)
    }

    fn push: (self, val :i64) {
        set self.items = lists.push(self.items val)
        set self.top = self.top + 1
    }

    fn pop: (self) :i64 {
        set val = lists.get(self.items self.top)
        set self.top = self.top - 1
        return val
    }

    fn is_empty: (self) :bool {
        return self.top < 0
    }
}

pub fn main: () {
    set s = Stack::new()
    s.push(10)
    s.push(20)
    s.push(30)

    set a = s.pop()
    set b = s.pop()
    set c = s.pop()

    use dasu("popped: {a}, {b}, {c}")
}
