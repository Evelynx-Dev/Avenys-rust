load kioto

struct Point {
    x :i64
    y :i64
}

fn create_point: (x_val :i64, y_val :i64) :Point {
    return (Point x: x_val, y: y_val)
}

fn distance: (p :Point) :i64 {
    return p.x * p.x + p.y * p.y
}

pub fn main: () {
    set p1 = create_point(3 4)
    set p2 = create_point(6 8)

    set d1 = distance(p1)
    set d2 = distance(p2)

    use dasu("p1 distance squared: {d1}")
    use dasu("p2 distance squared: {d2}")
}