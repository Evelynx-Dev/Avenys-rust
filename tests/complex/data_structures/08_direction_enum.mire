load kioto

enum Direction {
    North
    South
    East
    West
}

fn turn_right: (d :Direction) :Direction {
    match d {
        Direction.North {
            return Direction.East
        }
        Direction.East {
            return Direction.South
        }
        Direction.South {
            return Direction.West
        }
        Direction.West {
            return Direction.North
        }
    }
}

pub fn main: () {
    set d = Direction.North
    set d1 = turn_right(d)
    set d2 = turn_right(d1)
    set d3 = turn_right(d2)
    set d4 = turn_right(d3)

    use dasu("Turn sequence complete")
}