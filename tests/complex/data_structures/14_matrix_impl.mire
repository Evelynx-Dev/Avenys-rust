load kioto

struct Matrix {
    data :arr[i64 9]
    rows :i64
    cols :i64
}

impl Matrix {
    fn new: (rows :i64, cols :i64) :Matrix {
        return (Matrix data: [0 0 0 0 0 0 0 0 0] :arr[i64 9], rows: rows, cols: cols)
    }

    fn get: (self, row :i64, col :i64) :i64 {
        set idx = row * self.cols + col
        return self.data at idx
    }

    fn set_val: (self, row :i64, col :i64, val :i64) {
        set idx = row * self.cols + col
        set self.data at idx = val
    }
}

pub fn main: () {
    set m = Matrix::new(3 3)
    m.set_val(0 0 1)
    m.set_val(1 1 5)
    m.set_val(2 2 9)

    set v00 = m.get(0 0)
    set v11 = m.get(1 1)
    set v22 = m.get(2 2)

    use dasu("m[0][0]={v00} m[1][1]={v11} m[2][2]={v22}")
}