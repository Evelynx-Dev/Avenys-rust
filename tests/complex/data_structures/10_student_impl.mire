load kioto

struct Student {
    name :str
    grade :i64 mut
}

impl Student {
    fn new: (name :str, grade :i64) :Student {
        return (Student name: name, grade: grade)
    }

    fn promote: (self) {
        set self.grade = self.grade + 1
    }

    fn get_grade: (self) :i64 {
        return self.grade
    }
}

pub fn main: () {
    set s1 = Student::new("Alice" 90)
    set s2 = Student::new("Bob" 85)

    s1.promote()
    s2.promote()
    s2.promote()

    set g1 = s1.get_grade()
    set g2 = s2.get_grade()

    use dasu("Alice grade: {g1}")
    use dasu("Bob grade: {g2}")
}