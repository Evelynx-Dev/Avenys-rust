load kioto

struct Node {
    value :i64
    next :i64
}

fn create_node: (val :i64, next_idx :i64) :Node {
    return (Node value: val, next: next_idx)
}

pub fn main: () {
    set node0 = create_node(10 0 - 1)
    set node1 = create_node(20 0)
    set node2 = create_node(30 1)

    use dasu("Node0: value={node0.value} next={node0.next}")
    use dasu("Node1: value={node1.value} next={node1.next}")
    use dasu("Node2: value={node2.value} next={node2.next}")
}
