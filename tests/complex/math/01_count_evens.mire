import std

fn is_even: (n :i64) :bool {
    return (n % 2) == 0
}

fn count_evens: (arr :arr[i64 5]) :i64 {
    set count = 0 :i64 mut
    set i = 0 :i64 mut

    while i < 5 {
        set val = arr at i
        if is_even(val) {
            set count = count + 1
        }
        set i = i + 1
    }

    return count
}

pub fn main: () {
    set nums = [1 2 3 4 5] :arr[i64 5]
    set evens = count_evens(nums)
    use dasu("Even numbers: {evens}")
}
