load kioto
load strings
load math

pub fn main: () {
    set name = "mire" :str
    set upper = strings.to_upper(name)
    set lower = strings.to_lower(upper)
    set len = len(name)

    set nums = [1 2 3 4 5] :arr[i64 5]
    set sum = math.sum(nums)
    set avg = sum / 5

    use dasu("name={name} upper={upper} lower={lower} len={len}")
    use dasu("sum={sum} avg={avg}")
}