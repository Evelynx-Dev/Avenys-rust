load time as time
load lists as lists
load math as math

pub fn main: () {
set wall = time.mark() :i64 mut

set tasks = [] :vec[i64] mut
set tasks = lists.push(tasks 3)
set tasks = lists.push(tasks 2)
set tasks = lists.push(tasks 1)
set tasks = lists.push(tasks 5)

set total = math.sum(tasks)
use dasu("Total sum {total}")

set count = len(tasks)
use dasu("Count {count}")

set first = lists.get(tasks 0)
use dasu("First {first}")

use dasu("wall_ms {time.elapsed_ms(wall)}")
}