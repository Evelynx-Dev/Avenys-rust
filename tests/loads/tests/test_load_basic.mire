load kioto::strings
load kioto::math::basic

pub fn main: () {
    set upper = strings.to_upper("hello")
    use dasu(upper)

    set doubled = math.basic.add(21 21)
    use dasu(doubled)

    set sum = math.basic.add(10 20)
    use dasu(sum)

    set sq = math.basic.mul(4 4)
    use dasu(sq)

    set mx = math.basic.max(100 200)
    use dasu(mx)
}
