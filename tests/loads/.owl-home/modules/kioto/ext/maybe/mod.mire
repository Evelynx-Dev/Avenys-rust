pub fn some: (value) {
    return {tag: "some", value: value}
}

pub fn none: () {
    return {tag: "none"}
}

pub fn is_some: (m) :bool {
    return dicts.get(m "tag") == "some"
}

pub fn is_none: (m) :bool {
    return dicts.get(m "tag") != "some"
}

pub fn map: (m next_value) {
    if dicts.get(m "tag") == "some" {
        return {tag: "some", value: next_value}
    }
    return m
}

pub fn bind: (m next_maybe) :map[str anything] {
    if dicts.get(m "tag") == "some" {
        return next_maybe
    }
    return m
}

pub fn or_else: (m fallback) {
    if dicts.get(m "tag") == "some" {
        return dicts.get(m "value")
    }
    return fallback
}

pub fn unwrap: (m) {
    if dicts.get(m "tag") == "some" {
        return dicts.get(m "value")
    }
    return mu
}
