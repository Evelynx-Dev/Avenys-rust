load ./_externs

pub fn pi: () :f64 { return rt_math_pi() }
pub fn e: () :f64 { return rt_math_e() }
pub fn tau: () :f64 { return rt_math_tau() }

pub fn abs: (n :i64) :i64 { if n < 0 { return 0 - n } return n }
pub fn min: (a :i64, b :i64) :i64 { if a < b { return a } return b }
pub fn max: (a :i64, b :i64) :i64 { if a > b { return a } return b }
pub fn clamp: (n :i64, min :i64, max :i64) :i64 { if n < min { return min } if n > max { return max } return n }
pub fn sign: (n :i64) :i64 { if n < 0 { return -1 } if n > 0 { return 1 } return 0 }
pub fn square: (value :f64) :f64 { return value * value }
pub fn pow: (base :f64, exponent :f64) :f64 { return rt_math_pow(base, exponent) }
pub fn powi: (base :f64, exp :i64) :f64 {
    set result = 1.0 :f64 mut
    set i = 0 :i64 mut
    set n = exp mut
    if n < 0 {
        set n = 0 - n
    }
    while i < n {
        set result = result * base
        set i = i + 1
    }
    if exp < 0 {
        return 1.0 / result
    }
    return result
}
pub fn deg2rad: (value :f64) :f64 { return value * rt_math_pi() / 180.0 }
pub fn rad2deg: (value :f64) :f64 { return value * 180.0 / rt_math_pi() }
pub fn lerp: (a :f64, b :f64, t :f64) :f64 { return a + (b - a) * t }
pub fn clamp01: (value :f64) :f64 {
    if value < 0.0 { return 0.0 }
    if value > 1.0 { return 1.0 }
    return value
}
pub fn gcd: (a :i64, b :i64) :i64 {
    set x = a mut
    set y = b mut
    if x < 0 { set x = 0 - x }
    if y < 0 { set y = 0 - y }
    while y != 0 {
        set tmp = y
        set y = x % y
        set x = tmp
    }
    return x
}
pub fn lcm: (a :i64, b :i64) :i64 {
    if a == 0 || b == 0 { return 0 }
    return (a / gcd(a, b)) * b
}
pub fn hypot: (x :f64, y :f64) :f64 { return rt_math_sqrt(x * x + y * y) }
pub fn sqrt: (value :f64) :f64 { return rt_math_sqrt(value) }
pub fn sin: (value :f64) :f64 { return rt_math_sin(value) }
pub fn cos: (value :f64) :f64 { return rt_math_cos(value) }
pub fn tan: (value :f64) :f64 { return rt_math_tan(value) }
pub fn log: (value :f64) :f64 { return rt_math_log(value) }
pub fn log10: (value :f64) :f64 { return rt_math_log10(value) }
pub fn exp: (value :f64) :f64 { return rt_math_exp(value) }
pub fn atan2: (y :f64, x :f64) :f64 { return rt_math_atan2(y, x) }
pub fn asin: (value :f64) :f64 { return rt_math_asin(value) }
pub fn acos: (value :f64) :f64 { return rt_math_acos(value) }
pub fn round: (value :f64) :i64 { return rt_math_round(value) }
pub fn floor: (value :f64) :i64 { return rt_math_floor(value) }
pub fn ceil: (value :f64) :i64 { return rt_math_ceil(value) }
