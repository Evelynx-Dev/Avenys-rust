load kioto

pub fn main: () {
    set start = time.mark()
    set data = process_batch("user_data_1")
    set data2 = process_batch("user_data_2")
    set data3 = process_batch("user_data_3")
    set results = [data data2 data3]
    set elapsed = time.elapsed_ms(start)
    set mem_used = mem.process()
    use dasu("count {len(results)}")
    use dasu("elapsed_ms {elapsed}")
    use dasu("mem_bytes {mem_used}")
}

fn process_batch: (id: str) :str {
    set processed = "processed_" + id
    return processed
}
