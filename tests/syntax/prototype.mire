load kioto

struct Counter {
    value :i64 mut
    step :i64
}

impl Counter {
    fn new: (start :i64 step :i64) :Counter {
        return (Counter value: start, step: step)
    }

    fn increment: (self) {
        set self.value = self.value + self.step
    }

    fn value_of: (self) :i64 {
        return self.value
    }
}

enum Status {
    Ok
    Loading(progress :i64 total :i64)
}

fn classify: (n :i64) :Status {
    if n > 0 {
        return Status.Loading(progress: n, total: 10)
    }
    return Status.Ok
}

pub fn main: () {
    set c = Counter::new(1 2) mut
    c.increment()

    set arr = [1 2 3] :arr[i64 3] mut
    set arr at 1 = 9

    set nums = [] :vec[i64] mut
    set nums = lists.push(nums 4)
    set nums = lists.push(nums 7)

    set inner = {x: 1, y: 2} :map[str i64]
    set outer = {child: inner} :map[str map[str i64]]

    set status = classify(arr at 0)
    match status {
        Status.Ok {
            use dasu("ok")
        }
        Status.Loading(progress total) {
            use dasu("{progress}/{total}")
        }
    }

    use dasu(strings.join(strings.split("a--b--c" "--") "|"))
    use dasu(outer)
    use dasu(c.value_of())
}
