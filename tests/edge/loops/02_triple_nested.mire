import std

pub fn main: () {
    set result = 0 :i64 mut
    set i = 0 :i64 mut
    while i < 10 {
        set j = 0 :i64 mut
        while j < 10 {
            set k = 0 :i64 mut
            while k < 10 {
                set result = result + 1
                set k = k + 1
            }
            set j = j + 1
        }
        set i = i + 1
    }
    use dasu("10x10x10 = {result}")
}