import std

pub fn main: () {
    set result = 0 :i64 mut

    set i = 0 :i64 mut
    while i < 3 {
        set j = 0 :i64 mut
        while j < 3 {
            set k = 0 :i64 mut
            while k < 3 {
                set result = result + 1
                set k = k + 1
            }
            set j = j + 1
        }
        set i = i + 1
    }

    use dasu("3x3x3 nested loop result: {result}")
}
