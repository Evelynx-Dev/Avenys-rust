load kioto

fn safe_divide: (a :i64, b :i64) :i64 {
    if b == 0 {
        use dasu("Error: division by zero")
        return 0
    }
    return a / b
}

pub fn main: () {
    set result1 = safe_divide(10 2)
    set result2 = safe_divide(10 0)
    set result3 = safe_divide(100 7)

    use dasu("10 / 2 = {result1}")
    use dasu("10 / 0 = {result2}")
    use dasu("100 / 7 = {result3}")
}
