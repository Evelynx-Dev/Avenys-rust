import std

pub fn main: () {
    set arr = [10 20 30 40 50] :arr[i64 5]

    set v0 = arr at 0
    set v1 = arr at 1
    set v2 = arr at 2
    set v3 = arr at 3
    set v4 = arr at 4

    use dasu("Expected: arr[0]=10 arr[1]=20 arr[2]=30 arr[3]=40 arr[4]=50")
    use dasu("Actual:   arr[0]={v0} arr[1]={v1} arr[2]={v2} arr[3]={v3} arr[4]={v4}")
}