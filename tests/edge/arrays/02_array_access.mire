load kioto

pub fn main: () {
    set arr = [1 3 5 7 9 11 13 15] :arr[i64 8]

    set v0 = arr at 0
    set v1 = arr at 1
    set v2 = arr at 2
    set v3 = arr at 3
    set v4 = arr at 4
    set v5 = arr at 5
    set v6 = arr at 6
    set v7 = arr at 7

    use dasu("arr[0]={v0}")
    use dasu("arr[1]={v1}")
    use dasu("arr[2]={v2}")
    use dasu("arr[3]={v3}")
    use dasu("arr[4]={v4}")
    use dasu("arr[5]={v5}")
    use dasu("arr[6]={v6}")
    use dasu("arr[7]={v7}")
}