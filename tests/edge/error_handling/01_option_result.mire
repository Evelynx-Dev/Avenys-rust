import std

struct Result {
    ok :bool
    val :i64
}

fn divide: (a :i64, b :i64) :Result {
    if b == 0 {
        return (Result ok: false, val: 0)
    }
    return (Result ok: true, val: a / b)
}

fn safe_multiply: (a :i64, b :i64) :Result {
    set max_safe = 1000000 :i64
    if a > max_safe || b > max_safe {
        return (Result ok: false, val: 0)
    }
    return (Result ok: true, val: a * b)
}

pub fn main: () {
    set r1 = divide(10 2)
    set r2 = divide(10 0)
    set r3 = divide(100 7)

    set r4 = safe_multiply(5 6)
    set r5 = safe_multiply(2000000 2)

    use dasu("10/2={r1.val} ok={r1.ok}")
    use dasu("10/0={r2.val} ok={r2.ok}")
    use dasu("100/7={r3.val} ok={r3.ok}")
    use dasu("5*6={r4.val} ok={r4.ok}")
    use dasu("2M*2={r5.val} ok={r5.ok}")
}