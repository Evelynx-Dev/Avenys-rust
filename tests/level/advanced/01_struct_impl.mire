load kioto

struct Point {
    x :i64
    y :i64
}

impl Point {
    fn new: (x :i64, y :i64) :Point {
        return (Point x: x, y: y)
    }

    fn sum: (self) :i64 {
        return self.x + self.y
    }
}

pub fn main: () {
    set p = Point::new(3 4)
    set s = p.sum()
    use dasu("3 + 4 = {s}")
}