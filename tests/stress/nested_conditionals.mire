fn nested: (n: i64) :i64 {
  if n <= 0 {
    return 0
  }
  if n <= 1 {
    if n <= 0 {
      return 0
    }
    return 1
  }
  if n <= 2 {
    if n <= 1 {
      return nested(n - 1)
    }
    return nested(n - 2)
  }
  return nested(n - 1) + nested(n - 2)
}

set result = nested(10) :i64 mut

use dasu(result)