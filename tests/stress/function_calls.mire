fn add: (a: i64, b: i64) :i64 { return a + b }
fn sub: (a: i64, b: i64) :i64 { return a - b }
fn mul: (a: i64, b: i64) :i64 { return a * b }
fn div: (a: i64, b: i64) :i64 { 
  if b == 0 { return 0 } 
  return a / b 
}

set r1 = add(1 2) :i64 mut
set r2 = sub(r1 1) :i64 mut
set r3 = mul(r2 3) :i64 mut
set r4 = div(r3 2) :i64 mut
set r5 = add(r4 r3) :i64 mut
set r6 = sub(r5 r2) :i64 mut
set r7 = mul(r6 r1) :i64 mut
set r8 = div(r7 r2) :i64 mut

use dasu(r8)