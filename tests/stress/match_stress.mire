fn classify: (n: i64) :i64 {
  set mod3 = n % 3 :i64 mut
  set mod5 = n % 5 :i64 mut
  
  if mod3 == 0 {
    if mod5 == 0 {
      return 15
    }
    return 3
  }
  if mod3 == 1 {
    if mod5 == 0 {
      return 5
    }
    return 1
  }
  if mod3 == 2 {
    if mod5 == 0 {
      return 30
    }
    return 2
  }
  return 0
}

set sum = 0 :i64 mut
set i = 0 :i64 mut

while i < 100 {
  set sum = sum + classify(i)
  set i = i + 1
}

use dasu(sum)