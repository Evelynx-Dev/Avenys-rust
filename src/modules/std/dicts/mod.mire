pub fn len: (dict) :i64
pub fn keys: (dict) :vec[str]
pub fn values: (dict) :vec[i64]
pub fn has: (dict, key :str) :bool
pub fn get: (dict, key :str) :i64
pub fn set: (dict, key :str, value :i64)
pub fn remove: (dict, key :str)
pub fn delete: (dict, key :str)
pub fn entries: (dict) :vec[i64]
pub fn merge: (dict, other)
pub fn is_empty: (dict) :bool
