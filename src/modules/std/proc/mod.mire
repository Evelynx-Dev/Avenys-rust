pub fn run: (cmd :str, args :vec[str]) :i64
pub fn spawn: (cmd :str, args :vec[str]) :i64
pub fn pipe: (commands :vec[str]) :str
pub fn shell: (cmd :str) :str
pub fn read: () :str
pub fn write: (data :str)
pub fn on: (signal :str, handler)
pub fn exit: (code :i64)
pub fn err: () :str
pub fn exec: (cmd :str, args :vec[str]) :i64
pub fn exec_bg: (cmd :str, args :vec[str]) :i64
pub fn kill: (pid :i64)
pub fn wait: (pid :i64) :i64
pub fn exists: (pid :i64) :bool
