pub fn read: (path :str) :str
pub fn write: (path :str, data :str)
pub fn append: (path :str, data :str)
pub fn exists: (path :str) :bool
pub fn size: (path :str) :i64
pub fn copy: (src :str, dst :str)
pub fn move: (src :str, dst :str)
pub fn drop: (path :str)
pub fn list: (path :str) :vec[str]
pub fn mkdir: (path :str)
pub fn rmdir: (path :str)
pub fn join: (a :str, b :str) :str
pub fn dir: (path :str) :str
pub fn name: (path :str) :str
pub fn ext: (path :str) :str
