extern fn __kioto_term_style: (s :str, style :str) :str lib "c"
extern fn __kioto_term_hr: (ch :str, len :i64) :str lib "c"
extern fn __kioto_term_clear: () :str lib "c"

pub fn style: (s :str, style :str) :str { return __kioto_term_style(s, style) }
pub fn hr: (ch :str, len :i64) :str { return __kioto_term_hr(ch, len) }
pub fn clear: () :str { return __kioto_term_clear() }
