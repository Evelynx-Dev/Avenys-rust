extern fn __kioto_time_unix_ms: () :i64 lib "c"
extern fn __kioto_time_unix_ns: () :i64 lib "c"
extern fn __kioto_time_since_ms: (start :i64) :i64 lib "c"
extern fn __kioto_time_since_ns: (start :i64) :i64 lib "c"
extern fn __kioto_time_mark: () :i64 lib "c"
extern fn __kioto_time_elapsed_ms: (mark :i64) :i64 lib "c"
extern fn __kioto_time_elapsed_ns: (mark :i64) :i64 lib "c"
extern fn __kioto_time_elapsed_ms_str: (mark :i64) :str lib "c"
extern fn __kioto_time_sleep_ms: (ms :i64) lib "c"
extern fn __kioto_time_sleep_ns: (ns :i64) lib "c"

pub fn unix_ms: () :i64 { return __kioto_time_unix_ms() }
pub fn unix_ns: () :i64 { return __kioto_time_unix_ns() }
pub fn since_ms: (start :i64) :i64 { return __kioto_time_since_ms(start) }
pub fn since_ns: (start :i64) :i64 { return __kioto_time_since_ns(start) }
pub fn mark: () :i64 { return __kioto_time_mark() }
pub fn elapsed: (mark :i64) :i64 { return __kioto_time_elapsed_ms(mark) }
pub fn elapsed_ms: (mark :i64) :i64 { return __kioto_time_elapsed_ms(mark) }
pub fn elapsed_ns: (mark :i64) :i64 { return __kioto_time_elapsed_ns(mark) }
pub fn sleep_ms: (ms :i64) { __kioto_time_sleep_ms(ms) }
pub fn sleep_ns: (ns :i64) { __kioto_time_sleep_ns(ns) }
